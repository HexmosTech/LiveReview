# Example values for LiveReview scripts
# Copy to .env and set real values.
LIVEREVIEW_BITBUCKET_EMAIL=dev@example.com
LIVEREVIEW_BITBUCKET_USERNAME=devuser
LIVEREVIEW_BITBUCKET_API_TOKEN=fake_bitbucket_token
LIVEREVIEW_BITBUCKET_PR_URL=https://bitbucket.org/example/workspace/pull-requests/123
LIVEREVIEWBOT_HOST=127.0.0.1
LIVEREVIEWBOT_PORT=8888

# Gitea script credentials and defaults
GITEA_BASE_URL=https://gitea.example.com
GITEA_USER=example-user
GITEA_PASS=change_me
GITEA_ACCESS_TOKEN=change_me
GITEA_OWNER=example-org
GITEA_REPO=example-repo
GITEA_PR=1
GITEA_FILE=path/to/file.go
